# kebab.news — environment variables
# Copy to .env.local and fill in values. Never commit .env.local.

# =============================================================================
# Database — Neon Postgres
# =============================================================================
# Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
DATABASE_URL=

# =============================================================================
# AI providers
# =============================================================================
# Anthropic — used for framing annotation on publisher headlines/teasers.
ANTHROPIC_API_KEY=

# Voyage AI — used for embedding article text (voyage-3-lite, 512 dims).
VOYAGE_API_KEY=

# =============================================================================
# Cron auth
# =============================================================================
# Shared secret used to authorize Vercel-Cron requests to /api/cron/*.
CRON_SECRET=

# Daily-rotating salt for hashing voter IPs before storage. Rotate
# manually (any process you trust). Min 16 chars.
# Generate: openssl rand -base64 32
VOTE_DAILY_SALT=

# "true" lets Vercel-Cron auto-fire the ingest job every 30 min (per
# vercel.json). "false" (default) short-circuits scheduled hits — manual
# `bun ingest:run` still works regardless of this flag.
AUTOMATIC_CRON=false

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
