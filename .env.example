# kebab.news — environment variables
# Copy to .env.local and fill in values. Never commit .env.local.

# =============================================================================
# Database — Neon Postgres
# =============================================================================
# Use a dev branch for local work.
# Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
DATABASE_URL=

# =============================================================================
# AI providers
# =============================================================================
# Anthropic — used for framing annotation on publisher headlines/teasers.
ANTHROPIC_API_KEY=

# Voyage AI — used for embedding article text (voyage-3-lite, 512 dims).
VOYAGE_API_KEY=

# =============================================================================
# Cron auth
# =============================================================================
# Shared secret used to authorize Vercel-Cron requests to /api/cron/*.
# Generate: openssl rand -base64 32
CRON_SECRET=

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
