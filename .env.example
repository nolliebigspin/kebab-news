# kebab.news — environment variables
# Copy to .env.local and fill in values. Never commit .env.local.

# =============================================================================
# Database — Postgres (Neon today; any Postgres works via postgres-js)
# =============================================================================
# Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
DATABASE_URL=

# =============================================================================
# AI providers
# =============================================================================
# Anthropic — used for framing annotation on publisher headlines/teasers.
ANTHROPIC_API_KEY=

# Voyage AI — used for embedding article text (voyage-3-lite, 512 dims).
VOYAGE_API_KEY=

# =============================================================================
# Secrets
# =============================================================================
# Reserved shared secret (legacy, no longer gates an HTTP route). Min 16 chars.
CRON_SECRET=

# Daily-rotating salt for hashing voter IPs before storage. Rotate
# manually (any process you trust). Min 16 chars.
# Generate: openssl rand -base64 32
VOTE_DAILY_SALT=

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
