# kebab.news — environment variables
# Copy to .env.local and fill in values. Never commit .env.local.

# =============================================================================
# Database — Postgres (postgres-js; Neon or self-hosted Dokploy Postgres)
# =============================================================================
# Format: postgres://<user>:<password>@<host>:5432/<dbname>?sslmode=<mode>
#
# The Postgres image MUST ship pgvector (use pgvector/pgvector:pgNN), because
# migration 0000 runs `CREATE EXTENSION vector`.
#
# There are TWO connection contexts for the same DB:
#   - Worker (Dokploy container): internal Docker host, e.g.
#       postgres://USER:PASS@<internal-service-host>:5432/DBNAME?sslmode=disable
#   - Web (Vercel) + local migrations: externally reachable host + TLS, e.g.
#       postgres://USER:PASS@<public-host>:5432/DBNAME?sslmode=require
# Neon-only params like channel_binding do NOT apply to self-hosted Postgres.
DATABASE_URL=

# =============================================================================
# AI providers
# =============================================================================
# Anthropic — used for framing annotation on publisher headlines/teasers.
ANTHROPIC_API_KEY=

# Voyage AI — used for embedding article text (voyage-3-lite, 512 dims).
VOYAGE_API_KEY=

# =============================================================================
# Secrets
# =============================================================================
# Reserved shared secret (legacy, no longer gates an HTTP route). Min 16 chars.
CRON_SECRET=

# =============================================================================
# Auth (Better Auth — magic-link login). Only the web app needs these.
# =============================================================================
# Session-signing secret. Min 32 chars. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL Better Auth builds magic-link callbacks against.
# Local dev: http://localhost:3000 — production: https://kebab.news
BETTER_AUTH_URL=http://localhost:3000

# SMTP — used to send magic-link login emails (via nodemailer).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# From header for login emails. "kebab.news <login@kebab.news>" or a bare addr.
EMAIL_FROM=

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
