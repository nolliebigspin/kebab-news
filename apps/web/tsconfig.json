{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "preserve",
    "allowJs": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@kebab/env": ["../../packages/env/src/index.ts"],
      "@kebab/db": ["../../packages/db/src/index.ts"],
      "@kebab/core": ["../../packages/core/src/index.ts"],
      "@kebab/auth": ["../../packages/auth/src/index.ts"],
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
