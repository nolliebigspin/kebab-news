{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "allowJs": true,
    "plugins": [{ "name": "next" }],
    "types": ["node"],
    "paths": {
      "@kebab/env": ["./packages/env/src/index.ts"],
      "@kebab/db": ["./packages/db/src/index.ts"],
      "@kebab/core": ["./packages/core/src/index.ts"],
      "@/*": ["./apps/web/*"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/drizzle.config.ts",
    "apps/web/**/*.ts",
    "apps/web/**/*.tsx",
    "apps/worker/**/*.ts",
    "tests/**/*.ts",
    "apps/web/.next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "**/node_modules", "**/.next"]
}
